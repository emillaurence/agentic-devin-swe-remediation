# Devin API Configuration
DEVIN_API_KEY=your_devin_api_key_here
DEVIN_ORG_ID=your_devin_org_id_here

# GitHub API Configuration
GITHUB_TOKEN=your_github_token_here

# Default GitHub Repository
DEFAULT_GITHUB_OWNER=emillaurence
DEFAULT_GITHUB_REPO=superset

# Label Configuration
TRIGGER_LABEL=devin-remediate
STATUS_RUNNING_LABEL=status:devin-running
STATUS_NEEDS_REVIEW_LABEL=status:devin-needs-human-review
STATUS_COMPLETED_LABEL=status:devin-completed
STATUS_FAILED_LABEL=status:devin-failed

# Storage Configuration
STORE_PATH=./data/sessions.json

# Human Baseline Configuration (hours)
# Used for productivity KPI calculation to compare Devin time vs human time
HUMAN_BASELINE_QUALITY_HOURS=3
HUMAN_BASELINE_SECURITY_HOURS=10
HUMAN_BASELINE_OTHER_HOURS=6

# ROI Configuration
# Used for financial ROI calculation from actual time saved
BLENDED_ENGINEERING_HOURLY_COST=150
ROI_CURRENCY=A$

# Ngrok Configuration
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
